void print_answer(int32_t data[5])
{
    if (ntohl(data[4]))
        printf("%d %c %d = %d\n", ntohl(data[0]), (char)ntohl(data[3]), ntohl(data[1]), ntohl(data[2]));
    else
        printf("Operation impossible\n");
}

void usage(char *name) { fprintf(stderr, "USAGE: %s domain port \n", name); }

int main(int argc, char **argv)
{
    printf("%d\n",getpid());
    int fd;
    // int32_t data[5];
    if (argc != 3)
    {
        usage(argv[0]);
        return EXIT_FAILURE;
    }
    fd = connect_tcp_socket(argv[1], argv[2]);
    // prepare_request(argv, data);
    char pid[PID_SIZE];
    sprintf(pid, "%5d", getpid());

    printf("pid %s\n", pid);

    if (bulk_write(fd, (char *)pid, sizeof(pid)) < 0)
        ERR("write:");
    int16_t ret;
    if (bulk_read(fd, (char *)&ret, sizeof(int16_t)) < (int)sizeof(int16_t))
        ERR("read:");
    ret = ntohs(ret);
    printf("sum %d\n", ret);
    if (TEMP_FAILURE_RETRY(close(fd)) < 0)
        ERR("close");
    return EXIT_SUCCESS;
}
